# ─────────────────────────────────────────────────────────────────────────────
# Nexora – .env.example
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=production
APP_VERSION=1.0.0

# Ports (override for local dev)
HTTP_PORT=80
HTTPS_PORT=443

# Domain (used by nginx TLS config in production)
DOMAIN=nexora.example.com

# Database
DB_NAME=nexoradb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# Redis (set in production only)
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# Application secrets
JWT_SECRET=CHANGE_ME_min_32_char_random_string
API_KEY=CHANGE_ME_api_key_here

# Frontend
REACT_APP_API_URL=/api

# Logging
LOG_LEVEL=info

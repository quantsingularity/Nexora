# ─────────────────────────────────────────────────────────────────────────────
# Nexora – .env.example
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_ENV=production
APP_VERSION=1.0.0

# Ports (override for local dev)
HTTP_PORT=80
HTTPS_PORT=443

# Domain (used by nginx TLS config in production)
DOMAIN=nexora.example.com

# Backend (code/backend/app/core/config.py)
JWT_SECRET_KEY=CHANGE_ME_min_32_char_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
FHIR_SERVER_URL=http://mock-fhir-server/R4
CORS_ORIGINS=*

# Frontend (build-time only; Parcel inlines this into the JS bundle, so it
# must be set before `docker compose build`, not just before `up`). Defaults
# to a relative path proxied by the gateway nginx; only change this if the
# frontend is served from a different origin than the API.
REACT_APP_API_BASE_URL=/api

# Logging
LOG_LEVEL=INFO

# API Configuration: URL of the Nexora FastAPI backend (code/backend)
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# Application Settings
REACT_APP_DEFAULT_RECORDS_PER_PAGE=10
REACT_APP_MAX_FILE_UPLOAD_SIZE=10485760

# Analytics (Optional)
REACT_APP_ANALYTICS_ENABLED=false
REACT_APP_ANALYTICS_ID=

# Environment
NODE_ENV=development
